{
  "name": "talentflow-backend",
  "version": "1.0.0",
  "description": "TalentFlow - AI-powered internal talent marketplace for IBM",
  "main": "dist/src/server.js",
  "engines": {
    "node": ">=20.19.0"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/src/server.js",
    "dev": "tsx watch src/server.ts",
    "mock:w3-profile": "tsx mocks/w3-profile-api.ts",
    "mock:w3-cv": "tsx mocks/w3-cv-api.ts",
    "mock:prom": "tsx mocks/prom-seats-api.ts",
    "mock:agents": "tsx mocks/agent-server.ts",
    "mock:all": "concurrently \"npm:mock:w3-profile\" \"npm:mock:w3-cv\" \"npm:mock:prom\" \"npm:mock:agents\"",
    "db:migrate": "prisma migrate dev",
    "db:seed": "tsx prisma/seed.ts",
    "db:studio": "prisma studio",
    "ingest:employees": "tsx src/ingestion/ingestEmployees.ts",
    "ingest:seats": "tsx src/ingestion/ingestSeats.ts",
    "test": "echo \"No test runner configured\" && exit 0"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@sendgrid/mail": "^8.1.6",
    "axios": "^1.18.0",
    "bcrypt": "^6.0.0",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "helmet": "^8.2.0",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.22.0",
    "redis": "^6.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^26.0.0",
    "@types/pg": "^8.20.0",
    "concurrently": "^10.0.3",
    "nodemon": "^3.1.14",
    "prisma": "^7.8.0",
    "ts-node": "^10.9.2",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  }
}
