# Database
DATABASE_URL=postgresql://postgres:password@localhost:5432/talentflow
DIRECT_URL=postgresql://postgres:password@localhost:5432/talentflow

# Redis (Railway plugin)
REDIS_URL=redis://localhost:6379

# Auth
JWT_SECRET=replace-with-strong-random-secret
JWT_EXPIRY=8h

# Mock IBM API base URLs (point to localhost during dev, swap to real IBM endpoints in production)
W3_PROFILE_API_URL=http://localhost:4001
W3_CV_API_URL=http://localhost:4002
PROM_SEATS_API_URL=http://localhost:4003

# IBM Consulting Advantage agent endpoints (point to mock agent server during dev)
IBM_CA_EMBEDDING_AGENT_URL=http://localhost:4004/embed
IBM_CA_SKILL_EXTRACTION_AGENT_URL=http://localhost:4004/extract-skills
IBM_CA_EXPLANATION_AGENT_URL=http://localhost:4004/explain
IBM_CA_PROFORMA_CLASSIFIER_AGENT_URL=http://localhost:4004/classify-proforma

# Notifications
SENDGRID_API_KEY=
NOTIFICATION_THRESHOLD=70

# CORS
FRONTEND_ORIGIN=http://localhost:5173
